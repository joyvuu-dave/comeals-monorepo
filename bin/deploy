#!/usr/bin/env bash
set -euo pipefail

# ==============================================================================
# Comeals Deploy Script
#
# Deploys the monorepo (Rails + React) to Heroku as a single app.
#
# Smart deploy logic:
#   1. Compares local HEAD vs Heroku's deployed SHA.
#      Skips if already up to date.
#   2. Diffs db/migrate/ between the deployed and local SHAs.
#      - If migrations changed → maintenance deploy (scale to 0, push, scale up).
#      - If no migrations    → push deploy (brief downtime during restart).
#
# Heroku buildpack order: Node (Vite build) → Ruby (bundle + Sprockets).
# ==============================================================================

APP="comeals-backend"
APP_URL="https://comeals.com"
MAINTENANCE_ENABLED=false
DEPLOY_TIMESTAMP=""
NEEDS_MAINTENANCE=false
HEROKU_SHA=""

# --- Output helpers -----------------------------------------------------------

red()    { printf "\033[0;31m%s\033[0m\n" "$*"; }
green()  { printf "\033[0;32m%s\033[0m\n" "$*"; }
yellow() { printf "\033[0;33m%s\033[0m\n" "$*"; }
bold()   { printf "\033[1m%s\033[0m\n" "$*"; }

step() { printf "\n"; bold "==> $*"; }
info() { echo "    $*"; }
ok()   { green "    ✓ $*"; }
warn() { yellow "    ⚠ $*"; }
fail() { red "    ✗ $*"; }

# --- Cleanup trap -------------------------------------------------------------

cleanup() {
  local exit_code=$?
  if [ $exit_code -ne 0 ] && [ "$MAINTENANCE_ENABLED" = true ]; then
    echo
    red "============================================"
    red "  DEPLOY FAILED — MANUAL RECOVERY REQUIRED"
    red "============================================"
    echo
    yellow "App may still be in maintenance mode."
    yellow "Web dynos may be scaled to 0."
    yellow "Investigate the failure, then manually run:"
    echo
    echo "  heroku ps:scale web=1 -a $APP"
    echo "  heroku maintenance:off -a $APP"
    echo
  fi
}
trap cleanup EXIT

# --- Pre-flight checks --------------------------------------------------------

preflight_environment() {
  step "Pre-flight: environment"

  if ! command -v heroku &>/dev/null; then
    fail "heroku CLI not found in PATH"
    exit 1
  fi
  ok "heroku CLI found"

  if ! heroku auth:whoami &>/dev/null; then
    fail "Not logged into Heroku (run: heroku login)"
    exit 1
  fi
  local user
  user=$(heroku auth:whoami 2>/dev/null)
  ok "Logged into Heroku as $user"

  local remote_url
  remote_url=$(git remote get-url heroku 2>/dev/null || true)
  if [ -z "$remote_url" ]; then
    fail "No 'heroku' git remote"
    info "Run: heroku git:remote -a $APP"
    exit 1
  fi
  ok "heroku remote -> $remote_url"
}

preflight_repo() {
  step "Pre-flight: repository"

  local branch
  branch=$(git rev-parse --abbrev-ref HEAD)
  if [ "$branch" != "main" ]; then
    fail "On branch '$branch', expected 'main'"
    exit 1
  fi
  ok "On main branch"

  if [ -n "$(git status --porcelain)" ]; then
    fail "Uncommitted changes detected:"
    git status --short
    exit 1
  fi
  ok "Working tree clean"

  info "Fetching from origin..."
  git fetch origin -p -P --quiet

  local ahead behind
  ahead=$(git rev-list origin/main..HEAD --count)
  behind=$(git rev-list HEAD..origin/main --count)

  if [ "$ahead" -gt 0 ]; then
    fail "$ahead unpushed commit(s) on main"
    exit 1
  fi
  ok "No unpushed commits"

  if [ "$behind" -gt 0 ]; then
    info "Local is $behind commit(s) behind origin/main, pulling..."
    git pull --ff-only --quiet
    ok "Pulled $behind commit(s)"
  else
    ok "Up to date with origin/main"
  fi
}

preflight_quality() {
  step "Pre-flight: linting & tests"

  info "Running RuboCop..."
  bundle exec rubocop --parallel
  ok "RuboCop passed"

  info "Running RSpec..."
  bundle exec rspec
  ok "RSpec passed"

  info "Running ESLint..."
  npm run lint
  ok "ESLint passed"

  info "Running Vitest..."
  npm test
  ok "Vitest passed"
}

# --- Deploy detection ---------------------------------------------------------

detect_deploy_needs() {
  step "Detecting what needs to deploy"

  local local_sha heroku_sha
  local_sha=$(git rev-parse HEAD)
  heroku_sha=$(git ls-remote heroku refs/heads/main 2>/dev/null | awk '{print $1}')

  if [ -z "$heroku_sha" ]; then
    warn "Cannot read Heroku SHA (first deploy or endpoint unreachable)"
    info "Will deploy with maintenance mode for safety"
    NEEDS_MAINTENANCE=true
    return 0
  elif [ "$heroku_sha" = "$local_sha" ]; then
    ok "Already up to date (${local_sha:0:7})"
    return 1
  fi

  info "heroku=${heroku_sha:0:7} -> local=${local_sha:0:7}"
  HEROKU_SHA="$heroku_sha"
  return 0
}

detect_pending_migrations() {
  step "Checking for pending migrations"

  if [ -z "$HEROKU_SHA" ]; then
    return
  fi

  if ! git cat-file -e "$HEROKU_SHA" 2>/dev/null; then
    info "Heroku SHA not in local history — fetching from Heroku..."
    if git fetch heroku main --quiet 2>/dev/null; then
      ok "Fetched Heroku main branch"
    else
      warn "Cannot fetch from Heroku — assuming migrations needed"
      NEEDS_MAINTENANCE=true
      return
    fi

    if ! git cat-file -e "$HEROKU_SHA" 2>/dev/null; then
      warn "Heroku SHA still not in object store — assuming migrations needed"
      NEEDS_MAINTENANCE=true
      return
    fi
  fi

  local migration_diff
  if ! migration_diff=$(git diff --name-only "$HEROKU_SHA" HEAD -- db/migrate/ 2>/dev/null); then
    warn "git diff failed — assuming migrations needed"
    NEEDS_MAINTENANCE=true
    return
  fi

  if [ -n "$migration_diff" ]; then
    NEEDS_MAINTENANCE=true
    warn "Migration changes detected — maintenance deploy required:"
    echo "$migration_diff" | while IFS= read -r f; do
      info "  $f"
    done
  else
    ok "No migration changes — push deploy"
  fi
}

# --- Deploy functions ---------------------------------------------------------

enable_maintenance() {
  step "Enabling maintenance mode"
  heroku maintenance:on -a "$APP"
  ok "$APP maintenance ON"
  MAINTENANCE_ENABLED=true
}

disable_maintenance() {
  step "Disabling maintenance mode"
  heroku maintenance:off -a "$APP"
  ok "$APP maintenance OFF"
  MAINTENANCE_ENABLED=false
}

deploy_push() {
  step "Deploying ($APP)"

  info "Pushing main to Heroku..."
  git push heroku main --force
  ok "Code pushed — release phase complete"

  post_deploy_tasks
}

deploy_maintenance() {
  step "Deploying — maintenance ($APP)"

  info "Scaling web dynos to 0..."
  heroku ps:scale web=0 -a "$APP"
  ok "Web dynos scaled to 0"

  info "Pushing main to Heroku (release phase runs migrations)..."
  git push heroku main --force
  ok "Code pushed and migrations complete"

  post_deploy_tasks

  info "Scaling web dyno back up..."
  heroku ps:scale web=1 -a "$APP"
  ok "Web dyno running"
}

post_deploy_tasks() {
  info "Flushing MemCachier..."
  if heroku run bin/rails runner 'Rails.cache.clear' -a "$APP"; then
    ok "Cache flushed"
  else
    warn "Cache flush failed — stale entries may persist until naturally invalidated"
  fi

  info "Running billing:recalculate..."
  if heroku run bin/rake billing:recalculate -a "$APP"; then
    ok "Billing recalculated"
  else
    warn "billing:recalculate failed — balances may be stale until next daily run"
  fi
}

capture_backup() {
  step "Capturing database backup"
  heroku pg:backups:capture -a "$APP"
  ok "Backup complete"

  local backup_info
  backup_info=$(heroku pg:backups:info -a "$APP" 2>&1 || true)
  info "$backup_info"
}

# --- Post-deploy checks ------------------------------------------------------

check_logs() {
  step "Checking post-deploy logs"

  local logs
  logs=$(heroku logs -n 200 -s app -a "$APP" 2>&1 || true)

  local app_logs
  app_logs=$(echo "$logs" | awk -v ts="$DEPLOY_TIMESTAMP" '$1 >= ts' || true)

  if [ -z "$app_logs" ]; then
    ok "No application log output since deploy"
    return 0
  fi

  local issues=""

  local errors
  errors=$(echo "$app_logs" | grep -E "(ERROR|FATAL|RuntimeError|NoMethodError|NameError|TypeError|ArgumentError|PG::|Errno::)" || true)
  if [ -n "$errors" ]; then
    issues+="$errors"$'\n'
  fi

  local warnings
  warnings=$(echo "$app_logs" | grep -i -E "(WARN|DEPRECAT)" || true)
  if [ -n "$warnings" ]; then
    issues+="$warnings"$'\n'
  fi

  if [ -n "$issues" ]; then
    warn "Issues found in logs:"
    echo "$issues" | head -30 | while IFS= read -r line; do
      [ -n "$line" ] && echo "      $line"
    done
    local total
    total=$(echo "$issues" | grep -c . || true)
    if [ "$total" -gt 30 ]; then
      warn "...and $((total - 30)) more (run: heroku logs -n 500 -a $APP)"
    fi
  else
    ok "No errors, warnings, or deprecations found"
  fi
}

check_health() {
  step "Health check"

  local urls=("$APP_URL" "$APP_URL/api/v1/version")
  for url in "${urls[@]}"; do
    info "Curling $url ..."

    local attempts=0
    local max_attempts=12
    local status

    while [ $attempts -lt $max_attempts ]; do
      status=$(curl -sL -o /dev/null -w "%{http_code}" "$url" 2>/dev/null || echo "000")

      if [ "$status" = "200" ] || [ "$status" = "302" ]; then
        ok "$url returned HTTP $status"
        break
      fi

      attempts=$((attempts + 1))
      if [ $attempts -lt $max_attempts ]; then
        info "Got HTTP $status, retrying in 5s... ($attempts/$max_attempts)"
        sleep 5
      fi
    done

    if [ "$status" != "200" ] && [ "$status" != "302" ]; then
      fail "$url returned HTTP $status after $max_attempts attempts"
      exit 1
    fi
  done
}

# --- Main ---------------------------------------------------------------------

main() {
  bold "============================================"
  bold "  Comeals Deploy"
  bold "============================================"

  preflight_environment
  preflight_repo

  if ! detect_deploy_needs; then
    echo
    green "============================================"
    green "  Already up to date — nothing to deploy."
    green "============================================"
    exit 0
  fi

  detect_pending_migrations

  preflight_quality

  # --- Confirmation ---
  echo
  bold "Deploy plan:"
  echo

  local sha
  sha=$(git rev-parse --short HEAD)
  if [ "$NEEDS_MAINTENANCE" = true ]; then
    yellow "    $APP ($sha):  MAINTENANCE deploy (has migrations)"
  else
    green "    $APP ($sha):  PUSH deploy (no migrations)"
  fi
  git log --oneline -5 | while IFS= read -r line; do
    info "  $line"
  done

  echo
  printf "Continue? (y/n) "
  read -r confirm
  if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
    info "Aborted."
    exit 0
  fi

  DEPLOY_TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%S")

  capture_backup

  if [ "$NEEDS_MAINTENANCE" = true ]; then
    enable_maintenance
    deploy_maintenance
    disable_maintenance
  else
    deploy_push
  fi

  info "Waiting 10s for dynos to settle..."
  sleep 10

  check_logs
  check_health

  echo
  green "============================================"
  green "  Deploy complete!"
  green "============================================"
}

main "$@"
