#!/usr/bin/env bash
set -euo pipefail

if ! command -v foreman &> /dev/null; then
  echo "Installing foreman..."
  gem install foreman
fi

# Pass CLOCK_FAST=1 to fire all tasks every 2 minutes for easy observation.
# Example: CLOCK_FAST=1 bin/dev

echo ""
echo "  Mail inbox: http://localhost:3000/letter_opener"
echo ""

# Open mail inbox in the background once the server is up
(
  while ! curl -s -o /dev/null http://localhost:3000/letter_opener 2>/dev/null; do
    sleep 1
  done
  open http://localhost:3000/letter_opener
) &

exec foreman start -f Procfile.dev "$@"
