#!/usr/bin/env bash
set -euo pipefail

# In development the clock fires all tasks every 2 minutes (fast mode).
# Pass CLOCK_FAST=0 to run the real schedules instead.
# Example: CLOCK_FAST=0 bin/dev

echo ""
echo "  Comeals:       http://localhost:3036"
echo "  ActiveAdmin:   http://admin.lvh.me:3000/login"
echo "  Mail inbox:    http://localhost:3000/letter_opener"
echo ""

exec bundle exec foreman start -f Procfile.dev "$@"
