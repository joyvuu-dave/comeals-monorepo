{
  "name": "comeals",
  "version": "2.0.0",
  "description": "An app for managing common meals.",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": "24",
    "npm": "11"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@fontsource/roboto": "^5.2.10",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "axios": "^1.14.0",
    "dayjs": "^1.11.20",
    "js-cookie": "^3.0.5",
    "localforage": "^1.10.0",
    "mobx": "^6.13.7",
    "mobx-react": "^9.2.1",
    "mobx-state-tree": "^7.2.0",
    "normalize.css": "^8.0.1",
    "pretty-checkbox": "3.0.3",
    "pusher-js": "^8.4.3",
    "react": "^19.2.4",
    "react-big-calendar": "^1.17.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-modal": "^3.16.3",
    "react-router-dom": "^7.13.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "vite": "^8.0.8",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "build": "vite build && mkdir -p app/frontend/dist && mv public/index.html app/frontend/dist/index.html",
    "dev": "vite",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:update": "npx playwright test --update-snapshots",
    "test:integration": "bin/test-integration",
    "bench:modals": "PLAYWRIGHT_INCLUDE_ALL=1 npx playwright test tests/e2e/perf-modals.spec.js",
    "pwa:screenshots": "PLAYWRIGHT_INCLUDE_ALL=1 npx playwright test tests/e2e/pwa-screenshots.spec.js",
    "lint": "eslint app/frontend/src/",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  }
}
